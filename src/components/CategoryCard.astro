---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  slug: string;
  imagePath: any;
}

const { title, slug, imagePath } = Astro.props;
---
<a href={`/collezioni/${slug}`} class="group block relative overflow-hidden rounded-2xl bg-border/20 hover:shadow-xl transition-shadow duration-500">
  <div class="aspect-[4/5] w-full overflow-hidden">
    {imagePath ? (
      <Image 
        src={imagePath} 
        alt={`${title}`} 
        class="w-full h-full object-cover transform scale-100 group-hover:scale-105 transition-transform duration-700 ease-out"
        loading="lazy"
        width={500}
        height={625}
      />
    ) : (
      <div class="w-full h-full bg-border/20 flex items-center justify-center">
         <span class="text-text/20 uppercase tracking-widest text-xs">{title}</span>
      </div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent rounded-2xl"></div>
  </div>
  
  <div class="absolute inset-0 p-6 flex flex-col justify-end text-white">
    <h3 class="font-heading text-xl md:text-2xl font-medium mb-3 drop-shadow-md transform translate-y-2 group-hover:translate-y-0 transition-transform duration-400 ease-out">{title}</h3>
    <span class="inline-flex items-center gap-2 text-xs font-medium tracking-widest uppercase opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-400 delay-75 text-white/80">
      Scopri
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
