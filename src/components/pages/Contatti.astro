---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Image } from 'astro:assets';
import heroContatti from '../../assets/images/divani/Divani_pag_38.jpg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<Layout 
  title="Contatta Mega Shop Arredi | Mobili e Casalinghi Agrigento" 
  description="Contattaci per preventivi su arredi, cucine e casalinghi. Showroom ad Alessandria della Rocca (AG), al servizio di tutta la Sicilia e zona Monti Sicani.">
  <!-- Immersive Header -->
  <section class="relative h-[50vh] min-h-[400px] w-full bg-black flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 w-full h-full opacity-60">
      <Image src={heroContatti} alt="Contatti Hero" class="w-full h-full object-cover object-center" width={1920} height={600} loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/20"></div>
    </div>
    
    <div class="relative z-10 text-center text-white px-6 max-w-4xl mx-auto mt-16">
      <span class="block text-sm tracking-[0.4em] text-accent-text font-bold uppercase mb-6">{t('contact.badge')}</span>
      <h1 class="text-5xl md:text-7xl font-bold font-heading mb-6 text-white tracking-tight">{t('contact.title')}</h1>
      <p class="text-xl font-light text-white/80 leading-relaxed max-w-2xl mx-auto">
        {t('contact.subtitle')}
      </p>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="py-24 px-6 bg-primary border-b border-border/50">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-20 items-start">
      <div class="w-full lg:w-1/2">
        <h2 class="text-4xl md:text-5xl font-bold font-heading mb-8 text-text tracking-tight uppercase">
          {t('contact.form.title')}
        </h2>
        <div class="w-16 h-1 bg-accent mb-12"></div>
        
        {/* Success/Error Alerts */}
        <div id="form-status" class="mb-12 hidden transition-all duration-500 transform translate-y-2 opacity-0">
          <div id="status-success" class="hidden bg-accent/10 border border-accent/20 p-6 rounded-sm">
            <p class="text-accent-text font-bold flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {t('contact.form.success')}
            </p>
          </div>
          <div id="status-error" class="hidden bg-red-500/10 border border-red-500/20 p-6 rounded-sm">
            <p class="text-red-600 font-bold flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {t('contact.form.error')}
            </p>
          </div>
        </div>
        
        <form id="contact-form" action="/contact.php" method="POST" class="space-y-8">
          {/* Honeypot for Anti-spam (Hidden from humans) */}
          <div class="hidden" aria-hidden="true">
            <input type="text" name="website_honey_pot" tabindex="-1" autocomplete="off" />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label for="name" class="text-xs uppercase tracking-widest font-bold text-text/50 ml-1">{t('contact.form.name')}</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                placeholder="Mario Rossi"
                class="w-full bg-white border border-border/60 px-6 py-4 focus:border-accent focus:ring-0 transition-all outline-none rounded-sm text-text font-light"
              />
            </div>
            <div class="space-y-2">
              <label for="email" class="text-xs uppercase tracking-widest font-bold text-text/50 ml-1">{t('contact.form.email')}</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                placeholder="mario@esempio.it"
                class="w-full bg-white border border-border/60 px-6 py-4 focus:border-accent focus:ring-0 transition-all outline-none rounded-sm text-text font-light"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label for="phone" class="text-xs uppercase tracking-widest font-bold text-text/50 ml-1">{t('contact.form.phone')}</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                placeholder="+39 333 1234567"
                class="w-full bg-white border border-border/60 px-6 py-4 focus:border-accent focus:ring-0 transition-all outline-none rounded-sm text-text font-light"
              />
            </div>
            <div class="space-y-2">
              <label for="subject" class="text-xs uppercase tracking-widest font-bold text-text/50 ml-1">{t('contact.form.subject')}</label>
              <select 
                id="subject" 
                name="subject" 
                class="w-full bg-white border border-border/60 px-6 py-4 focus:border-accent focus:ring-0 transition-all outline-none rounded-sm text-text font-light appearance-none cursor-pointer"
              >
                <option value={t('contact.form.subject.info')}>{t('contact.form.subject.info')}</option>
                <option value={t('contact.form.subject.kitchen')}>{t('contact.form.subject.kitchen')}</option>
                <option value={t('contact.form.subject.night')}>{t('contact.form.subject.night')}</option>
                <option value={t('contact.form.subject.day')}>{t('contact.form.subject.day')}</option>
                <option value={t('contact.form.subject.other')}>{t('contact.form.subject.other')}</option>
              </select>
            </div>
          </div>

          <div class="space-y-2">
            <label for="message" class="text-xs uppercase tracking-widest font-bold text-text/50 ml-1">{t('contact.form.message')}</label>
            <textarea 
              id="message" 
              name="message" 
              rows="5" 
              required 
              placeholder="..."
              class="w-full bg-white border border-border/60 px-6 py-4 focus:border-accent focus:ring-0 transition-all outline-none rounded-sm text-text font-light resize-none"
            ></textarea>
          </div>

          <button type="submit" class="inline-flex items-center justify-center bg-accent text-black px-10 py-5 hover:bg-black transition-all duration-300 font-bold text-sm tracking-widest uppercase shadow-lg hover:shadow-xl rounded-sm group">
            <span class="mr-3">{t('contact.form.send')}</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </form>
      </div>

      <div class="w-full lg:w-1/2 lg:mt-24">
        <div class="bg-primary border border-border/50 p-10 md:p-16 space-y-12 relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-accent/5 rounded-full -mr-16 -mt-16 transition-transform duration-700 group-hover:scale-150"></div>
          
          <div class="relative z-10 flex items-start gap-8">
            <div class="w-12 h-12 bg-accent text-black flex items-center justify-center rounded-full shrink-0 shadow-md">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold font-heading mb-2 uppercase tracking-wide">{t('contact.call')}</h3>
              <p class="text-text/60 font-light mb-1">Domenico Puglia</p>
              <a href="tel:3312527613" class="text-xl md:text-2xl font-bold text-accent-text hover:text-text transition-colors break-all">+39 331 252 7613</a>
            </div>
          </div>

          <div class="relative z-10 flex items-start gap-8 border-t border-border/30 pt-10">
            <div class="w-12 h-12 bg-accent text-black flex items-center justify-center rounded-full shrink-0 shadow-md">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold font-heading mb-4 uppercase tracking-wide">Social</h3>
              <div class="flex gap-6">
                <a href={t('social.facebook')} target="_blank" rel="noopener noreferrer" class="p-3 bg-white border border-border/60 rounded-full hover:bg-accent hover:border-accent transition-all duration-300 text-text/70 hover:text-black group-social shadow-sm" aria-label="Facebook">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                </a>
                <a href={t('social.instagram')} target="_blank" rel="noopener noreferrer" class="p-3 bg-white border border-border/60 rounded-full hover:bg-accent hover:border-accent transition-all duration-300 text-text/70 hover:text-black group-social shadow-sm" aria-label="Instagram">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                </a>
                <a href={t('social.tiktok')} target="_blank" rel="noopener noreferrer" class="p-3 bg-white border border-border/60 rounded-full hover:bg-accent hover:border-accent transition-all duration-300 text-text/70 hover:text-black group-social shadow-sm" aria-label="TikTok">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Info & Map Section -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-20">
      <div class="space-y-16">
        <div>
          <h2 class="text-3xl font-heading font-bold mb-8 flex items-center gap-5 text-text tracking-tight">
            <div class="w-14 h-14 bg-accent/10 flex items-center justify-center rounded-full text-accent-text shadow-inner border border-accent/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            {t('home.visit')}
          </h2>
          <div class="text-text/70 font-light ml-0 md:ml-20 text-lg">
            <a href="https://maps.app.goo.gl/uYutyV15jDfAmnhV6" target="_blank" rel="noopener noreferrer" class="transition-colors duration-300 hover:text-accent-text hover:underline block">
              <p>Via Nazionale, 4</p>
              <p>92010 Alessandria della Rocca (AG)</p>
            </a>
          </div>
        </div>
        
        <div>
          <h2 class="text-3xl font-heading font-bold mb-8 flex items-center gap-5 text-text tracking-tight">
             <div class="w-14 h-14 bg-accent/10 flex items-center justify-center rounded-full text-accent-text shadow-inner border border-accent/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            {t('footer.hours')}
          </h2>
          <div class="text-text/70 font-light ml-0 md:ml-20 text-lg">
            <table class="w-full max-w-sm border-collapse">
              <tbody>
                <tr class="border-b border-border/60">
                  <td class="py-4 font-semibold text-text">{t('footer.hours.val1')}</td>
                  <td class="py-4 text-right">09:00 - 13:00<br/>16:00 - 20:00</td>
                </tr>
                <tr>
                  <td class="py-4 font-semibold text-text">{t('footer.hours.val4').split(':')[0]}</td>
                  <td class="py-4 text-right text-accent-text font-bold tracking-widest uppercase text-sm">{t('footer.hours.val4').split(':')[1]}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <div class="h-[500px] w-full bg-border/20 relative flex items-center justify-center group shadow-xl overflow-hidden rounded-sm">
        <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1575.6791986423456!2d13.4471032!3d37.5615797!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x131a1532f1ea38d5%3A0xc3af87265a7f2dc1!2sVia%20Nazionale%2C%204%2C%2092010%20Alessandria%20della%20Rocca%20AG!5e0!3m2!1sit!2sit!4v1703164996457!5m2!1sit!2sit" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="absolute inset-0 grayscale contrast-125 opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700"
            title={t('home.map.title')}
        ></iframe>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Handle Success/Error message display based on URL params
  const urlParams = new URLSearchParams(window.location.search);
  const success = urlParams.get('success');
  const alertContainer = document.getElementById('form-status');
  const successAlert = document.getElementById('status-success');
  const errorAlert = document.getElementById('status-error');

  if ((success === 'true' || success === 'false') && alertContainer) {
    alertContainer.classList.remove('hidden');
    
    // Trigger animation
    requestAnimationFrame(() => {
      alertContainer.classList.remove('opacity-0', 'translate-y-2');
      alertContainer.classList.add('opacity-100', 'translate-y-0');
    });

    if (success === 'true' && successAlert) {
      successAlert.classList.remove('hidden');
    } else if (success === 'false' && errorAlert) {
      errorAlert.classList.remove('hidden');
    }

    // Scroll to the alert if it's there
    alertContainer.scrollIntoView({ behavior: 'smooth', block: 'center' });
    
    // Clean up the URL without reloading to avoid repeated alerts on refresh
    const cleanUrl = window.location.pathname + window.location.hash;
    window.history.replaceState({}, document.title, cleanUrl);
  }
</script>
