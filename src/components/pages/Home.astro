---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';
import { Image } from 'astro:assets';
import hero1 from '../../assets/hero/hero-1.jpg';
import hero2 from '../../assets/hero/hero-2.jpg';
import hero3 from '../../assets/hero/hero-3.jpg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const allTendaggi = import.meta.glob('../../assets/images/immagini_tendaggi/*.{jpeg,jpg,png,webp}', { eager: true });
const tendaggiList = Object.keys(allTendaggi).sort().map(p => (allTendaggi[p] as any).default);
const getImg = (idx: number) => tendaggiList[idx] ?? null;

const allBinari     = import.meta.glob('../../assets/images/binari/*.{jpeg,jpg,png,webp}', { eager: true });
const allDevore     = import.meta.glob('../../assets/images/devorè/*.{jpeg,jpg,png,webp}', { eager: true });
const allJeorgette  = import.meta.glob('../../assets/images/jeorgette-in-seta/*.{jpeg,jpg,png,webp}', { eager: true });
const allJeorCal    = import.meta.glob('../../assets/images/jeorgette-in-seta-con-calata-o-velluto/*.{jpeg,jpg,png,webp}', { eager: true });
const allMistoLino  = import.meta.glob('../../assets/images/misto-lino/*.{jpeg,jpg,png,webp}', { eager: true });
const allOceania    = import.meta.glob('../../assets/images/oceania/*.{jpeg,jpg,png,webp}', { eager: true });

const first = (g: Record<string, any>) => Object.values(g)[0]?.default ?? null;

const categories = [
  { titleKey: 'cat.tende-interno' as const, slug: "tende-interno", img: getImg(5)  },
  { titleKey: 'cat.tende-misura'  as const, slug: "tende-misura",  img: getImg(46) },
  { titleKey: 'cat.binari'        as const, slug: "binari",        img: first(allBinari) },
  { titleKey: 'cat.tende-rullo'   as const, slug: "tende-rullo",   img: getImg(29) },
  { titleKey: 'cat.veneziane'     as const, slug: "veneziane",     img: getImg(51) },
  { titleKey: 'cat.tessuti'       as const, slug: "tessuti",       img: getImg(1)  },
];

const tessuti = [
  { titleKey: 'cat.devore'            as const, slug: "devore",           img: first(allDevore)    },
  { titleKey: 'cat.jeorgette-seta'    as const, slug: "jeorgette-seta",   img: first(allJeorgette) },
  { titleKey: 'cat.jeorgette-calata'  as const, slug: "jeorgette-calata", img: first(allJeorCal)   },
  { titleKey: 'cat.misto-lino'        as const, slug: "misto-lino",       img: first(allMistoLino) },
  { titleKey: 'cat.oceania'           as const, slug: "oceania",          img: first(allOceania)   },
];
---

<Layout
  title={t('home.meta.title')}
  description="Marco Tendaggi — Tende su misura, tessuti pregiati e binari di qualità. Preventivi gratuiti in tutta Italia. Showroom a Ribera (AG), Via Canova 15.">

  <!-- ░░ HERO ░░ -->
  <section class="relative h-[92vh] md:h-screen min-h-[600px] w-full bg-text flex items-end overflow-hidden">
    <Image src={hero1} alt="Tende su misura Marco Tendaggi" class="absolute inset-0 w-full h-full object-cover hero-slide hero-delay-1" loading="eager" fetchpriority="high" width={1920} height={1080} />
    <Image src={hero2} alt="Tessuti pregiati" class="absolute inset-0 w-full h-full object-cover hero-slide hero-delay-2" loading="lazy" width={1920} height={1080} />
    <Image src={hero3} alt="Tende da esterno" class="absolute inset-0 w-full h-full object-cover hero-slide hero-delay-3" loading="lazy" width={1920} height={1080} />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/10"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 sm:px-10 pb-16 md:pb-24">
      <div class="max-w-2xl">
        <p class="text-white/70 text-sm tracking-[0.25em] uppercase font-medium mb-4">{t('home.hero.location')}</p>
        <h1 class="font-heading text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-white font-medium leading-[1.05] mb-8">
          {t('home.hero.h1.line1')}<br/>
          <em class="not-italic text-white">{t('home.hero.h1.line2')}</em>
        </h1>
        <p class="text-white/80 text-lg font-light leading-relaxed mb-10 max-w-lg">
          {t('home.hero.desc')}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#collezioni" class="btn-pill">{t('hero.cta')}</a>
          <a href="/contatti" class="btn-pill-outline !border-white !text-white hover:!bg-white hover:!text-accent">{t('nav.chiamaci')}</a>
        </div>
      </div>
    </div>
    <div class="absolute top-8 right-8 hidden md:flex flex-col items-end gap-2 z-10">
      <span class="bg-white/15 backdrop-blur-sm text-white text-xs tracking-widest uppercase px-4 py-2 rounded-full border border-white/20 font-medium">✔ {t('home.markets.pe')}</span>
      <span class="bg-white/15 backdrop-blur-sm text-white text-xs tracking-widest uppercase px-4 py-2 rounded-full border border-white/20 font-medium">✔ {t('home.markets.fav')}</span>
    </div>
  </section>

  <!-- ░░ STRIP SERVIZI ░░ -->
  <section class="bg-surface border-b border-border/50">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 py-10">
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-border/50">
        <div class="flex items-center gap-5 py-6 md:py-0 md:px-8 first:md:pl-0">
          <div class="w-10 h-10 rounded-full bg-accent/15 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent-text" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <p class="font-semibold text-text text-sm">{t('home.service1.title')}</p>
            <p class="text-text-muted text-xs mt-0.5 leading-relaxed">{t('home.service1.desc')}</p>
          </div>
        </div>
        <div class="flex items-center gap-5 py-6 md:py-0 md:px-8">
          <div class="w-10 h-10 rounded-full bg-accent/15 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent-text" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          </div>
          <div>
            <p class="font-semibold text-text text-sm">{t('home.service2.title')}</p>
            <p class="text-text-muted text-xs mt-0.5 leading-relaxed">{t('home.service2.desc')}</p>
          </div>
        </div>
        <div class="flex items-center gap-5 py-6 md:py-0 md:px-8">
          <div class="w-10 h-10 rounded-full bg-accent/15 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent-text" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <div>
            <p class="font-semibold text-text text-sm">{t('home.service3.title')}</p>
            <p class="text-text-muted text-xs mt-0.5 leading-relaxed">{t('home.service3.desc')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ COLLEZIONI ░░ -->
  <section id="collezioni" class="py-20 md:py-28 px-6 sm:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
        <div>
          <p class="text-accent-text text-xs tracking-[0.25em] uppercase font-medium mb-3">{t('home.products.label')}</p>
          <h2 class="font-heading text-4xl md:text-5xl text-text font-medium leading-tight">{t('collections.title')}</h2>
        </div>
        <p class="text-text-muted font-light max-w-xs text-sm leading-relaxed md:text-right">{t('collections.subtitle')}</p>
      </div>

      <!-- griglia 2 grandi + 4 piccole -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-5">
        {categories[0] && (
          <a href={`/collezioni/${categories[0].slug}`} class="md:col-span-7 group relative overflow-hidden rounded-2xl bg-border/20 block">
            <div class="aspect-[4/3] md:aspect-auto md:h-[480px] overflow-hidden">
              {categories[0].img
                ? <Image src={categories[0].img} alt={t(categories[0].titleKey)} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="eager" width={900} height={600} />
                : <div class="w-full h-full bg-border/30 flex items-center justify-center"><span class="text-text/30 text-sm uppercase tracking-wider">{t(categories[0].titleKey)}</span></div>
              }
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent rounded-2xl"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="font-heading text-2xl md:text-3xl text-white font-medium mb-2">{t(categories[0].titleKey)}</h3>
              <span class="inline-flex items-center gap-2 text-white/80 text-xs uppercase tracking-widest font-medium group-hover:text-white transition-colors">{t('home.hero.discover')} <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg></span>
            </div>
          </a>
        )}
        {categories[1] && (
          <a href={`/collezioni/${categories[1].slug}`} class="md:col-span-5 group relative overflow-hidden rounded-2xl bg-border/20 block">
            <div class="aspect-[4/3] md:aspect-auto md:h-[480px] overflow-hidden">
              {categories[1].img
                ? <Image src={categories[1].img} alt={t(categories[1].titleKey)} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="eager" width={700} height={600} />
                : <div class="w-full h-full bg-border/30 flex items-center justify-center"><span class="text-text/30 text-sm uppercase tracking-wider">{t(categories[1].titleKey)}</span></div>
              }
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent rounded-2xl"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="font-heading text-2xl text-white font-medium mb-2">{t(categories[1].titleKey)}</h3>
              <span class="inline-flex items-center gap-2 text-white/80 text-xs uppercase tracking-widest font-medium group-hover:text-white transition-colors">{t('home.hero.discover')} <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg></span>
            </div>
          </a>
        )}
        {categories.slice(2).map(cat => (
          <a href={`/collezioni/${cat.slug}`} class="md:col-span-3 group relative overflow-hidden rounded-2xl bg-border/20 block">
            <div class="aspect-square overflow-hidden">
              {cat.img
                ? <Image src={cat.img} alt={t(cat.titleKey)} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" width={500} height={500} />
                : <div class="w-full h-full bg-border/30 flex items-center justify-center"><span class="text-text/30 text-xs uppercase tracking-wider">{t(cat.titleKey)}</span></div>
              }
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-transparent to-transparent rounded-2xl"></div>
            <div class="absolute bottom-4 left-4 right-4">
              <h3 class="font-heading text-base md:text-lg text-white font-medium leading-snug mb-1">{t(cat.titleKey)}</h3>
              <span class="inline-flex items-center gap-1.5 text-white/70 text-[10px] uppercase tracking-widest font-medium group-hover:text-white transition-colors">{t('home.hero.discover')} <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ TESSUTI PREGIATI (nuova sezione) ░░ -->
  <section class="py-16 md:py-24 px-6 sm:px-10 bg-surface border-y border-border/50">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12">
        <div>
          <p class="text-accent-text text-xs tracking-[0.25em] uppercase font-medium mb-3">{t('home.fabrics.label')}</p>
          <h2 class="font-heading text-4xl md:text-5xl text-text font-medium leading-tight">{t('home.fabrics.title')}</h2>
        </div>
        <p class="text-text-muted font-light max-w-xs text-sm leading-relaxed md:text-right">{t('home.fabrics.subtitle')}</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        {tessuti.map(item => (
          <a href={`/collezioni/${item.slug}`} class="group relative overflow-hidden rounded-xl bg-border/20 block">
            <div class="aspect-[3/4] overflow-hidden">
              {item.img
                ? <Image src={item.img} alt={t(item.titleKey)} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" width={400} height={540} />
                : <div class="w-full h-full bg-border/30 flex items-center justify-center"><span class="text-text/30 text-xs uppercase tracking-wider text-center p-2">{t(item.titleKey)}</span></div>
              }
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent rounded-xl"></div>
            <div class="absolute bottom-3 left-3 right-3">
              <h3 class="font-heading text-sm md:text-base text-white font-medium leading-snug">{t(item.titleKey)}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ CHI SIAMO preview ░░ -->
  <section class="py-20 md:py-28 border-b border-border/50">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-24 items-center">
      <div>
        <p class="text-accent-text text-xs tracking-[0.25em] uppercase font-medium mb-4">{t('home.about.label')}</p>
        <h2 class="font-heading text-4xl md:text-5xl text-text font-medium leading-tight mb-8">{t('home.about.title')}</h2>
        <p class="text-text-muted font-light leading-relaxed mb-5 text-base">{t('home.about.p1')}</p>
        <p class="text-text-muted font-light leading-relaxed mb-10 text-base">{t('home.about.p2')}</p>
        <a href={translatePath('/chi-siamo')} class="btn-pill-outline">
          {t('home.about.cta')}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div class="col-span-2 aspect-[16/9] rounded-xl overflow-hidden">
          {getImg(5) && <Image src={getImg(5)} class="w-full h-full object-cover" alt="Marco Tendaggi showroom" loading="lazy" width={900} height={500} />}
        </div>
        <div class="aspect-square rounded-xl overflow-hidden">
          {getImg(46) && <Image src={getImg(46)} class="w-full h-full object-cover" alt="Tessuti pregiati" loading="lazy" width={450} height={450} />}
        </div>
        <div class="aspect-square rounded-xl overflow-hidden">
          {getImg(94) && <Image src={getImg(94)} class="w-full h-full object-cover" alt="Binari qualità" loading="lazy" width={450} height={450} />}
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ DOVE SIAMO ░░ -->
  <section class="py-20 md:py-28 px-6 sm:px-10">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-start">
      <div>
        <p class="text-accent-text text-xs tracking-[0.25em] uppercase font-medium mb-4">{t('home.visit')}</p>
        <h2 class="font-heading text-4xl md:text-5xl text-text font-medium leading-tight mb-10">{t('home.visit.subtitle')}</h2>
        <div class="space-y-6 text-sm">
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-full bg-accent/15 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent-text" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <p class="font-semibold text-text mb-1">Showroom</p>
              <a href="https://maps.app.goo.gl/Gpne85oJ72oiizYH6" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent-text transition-colors leading-relaxed">Via Canova 15 (il cangurotto)<br/>92016 Ribera (AG)</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-full bg-accent/15 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent-text" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            </div>
            <div>
              <p class="font-semibold text-text mb-1">{t('home.phone')}</p>
              <a href="tel:3287323742" class="text-text-muted hover:text-accent-text transition-colors">328 732 3742</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-full bg-accent/15 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent-text" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            </div>
            <div>
              <p class="font-semibold text-text mb-2">{t('home.markets.title')}</p>
              <p class="text-text-muted leading-relaxed">✔ {t('home.markets.pe')}<br/>✔ {t('home.markets.fav')}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="h-[420px] md:h-[500px] rounded-2xl overflow-hidden shadow-lg border border-border/40 relative">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3151.7770830492817!2d13.2623196!3d37.4934829!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x131a6bf75a37104d%3A0xfa5f755a4648f712!2sIl%20Cangurotto%20-%20Tendaggi-%20Intimo%20%26%20Corredo!5e0!3m2!1sit!2sit!4v1718800000000!5m2!1sit!2sit"
          width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="absolute inset-0"
          title="Mappa Marco Tendaggi Ribera AG">
        </iframe>
      </div>
    </div>
  </section>

  <!-- ░░ CTA FINALE ░░ -->
  <section class="bg-text py-20 md:py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-heading text-4xl md:text-5xl text-white font-medium leading-tight mb-6">{t('home.cta.title1')}<br/>{t('home.cta.title2')}</h2>
      <p class="text-white/60 font-light text-base mb-10 max-w-md mx-auto leading-relaxed">{t('home.cta.desc')}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={translatePath('/contatti')} class="btn-pill !bg-white !text-text hover:!bg-white">{t('home.cta.btn')}</a>
        <a href="tel:3287323742" class="btn-pill-outline !border-white/30 !text-white/80 hover:!bg-white/10 hover:!border-white/60 hover:!text-white">328 732 3742</a>
      </div>
    </div>
  </section>

</Layout>
