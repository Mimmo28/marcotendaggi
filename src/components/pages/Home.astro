---
import Layout from '../../layouts/Layout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

import { Image } from 'astro:assets';
import hero1 from '../../assets/hero/hero-1.png';
import hero2 from '../../assets/hero/hero-2.jpg';
import hero3 from '../../assets/hero/hero-3.jpg';
import hero4 from '../../assets/hero/hero-4.jpg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Use import.meta.glob to read all images from assets
const allImages = import.meta.glob('../../assets/images/**/*.{jpeg,jpg,png,webp}', { eager: true });
const allBrands = import.meta.glob('../../assets/images/brand/**/*.{jpeg,jpg,png,webp}', { eager: true });

// Helper to get first image of a category (returns the imported module object)
const getCoverForCategory = (folderName: string) => {
  const path = Object.keys(allImages).find(path => path.includes(`/assets/images/${folderName}/`));
  return path ? (allImages[path] as any).default : null;
}

const categories = [
  { title: "Cucine", slug: "cucine" },
  { title: "Divani", slug: "divani" },
  { title: "Camere da Letto", slug: "camere" },
  { title: "Camerette", slug: "camerette" },
  { title: "Pareti Attrezzate", slug: "pareti" },
  { title: "Sale", slug: "sale" },
  { title: "Mobili Porta TV", slug: "mobili_porta_tv" },
  { title: "Tavoli / Consolle / Tavolini", slug: "tavoli" },
  { title: "Madie & Contenitori", slug: "madie_contenitori" },
  { title: "Ufficio", slug: "ufficio" },
  { title: "Librerie", slug: "librerie" },
  { title: "Mobili Ingresso", slug: "mobili_ingresso" },
  { title: "Scarpiere & Multi-Uso", slug: "scarpiere" },
  { title: "Letti Contenitore", slug: "letto-contenitore" },
  { title: "Arredo Giardino", slug: "arredo_giardino_contract_spiaggia" },
];

const brandImageObjects = Object.keys(allBrands).map(path => {
  const parts = path.split('/');
  return { path: (allBrands[path] as any).default, brand: parts[5] }; // assets/images/brand/[brand]/...
});

const brands = [
  { name: 'Catilan Soggiorni', slug: 'catilan_soggiorni' },
  { name: 'Divancasa', slug: 'divancasa' },
  { name: 'Proxima Mobili', slug: 'proxima_mobili' }
];

const brandsWithImages = brands.map(brand => {
  const bImages = brandImageObjects.filter(b => b.brand === brand.slug).map(b => b.path).slice(0, 3);
  return { ...brand, images: bImages };
});

const heroImage = getCoverForCategory('divani');
---

<Layout 
  title="Arredamento e Casalinghi Agrigento | Monti Sicani" 
  description="Scopri Mega Shop Arredi ad Alessandria della Rocca: mobili, cucine e casalinghi per tutta la provincia di Agrigento e la Sicilia. Arredamento di qualità Made in Italy.">
  <!-- Hero Section (Full Screen Made in Italy Luxury) -->
  <section class="relative h-[85vh] md:h-screen min-h-[500px] md:min-h-[700px] w-full bg-black flex items-center justify-center overflow-hidden">
    <!-- Image Slider Optimized with astro:assets -->
    <Image src={hero1} alt="Sfondo Home 1" class="absolute inset-0 w-full h-full object-cover hero-slide hero-delay-1" loading="eager" fetchpriority="high" width={1920} height={1080} />
    <Image src={hero2} alt="Sfondo Home 2" class="absolute inset-0 w-full h-full object-cover hero-slide hero-delay-2" loading="lazy" width={1920} height={1080} />
    <Image src={hero3} alt="Sfondo Home 3" class="absolute inset-0 w-full h-full object-cover hero-slide hero-delay-3" loading="lazy" width={1920} height={1080} />
    <Image src={hero4} alt="Sfondo Home 4" class="absolute inset-0 w-full h-full object-cover hero-slide hero-delay-4" loading="lazy" width={1920} height={1080} />

    
    <!-- Protective Overlay -->
    <div class="absolute inset-0 bg-black/40"></div>
    
    <div class="relative z-10 text-center text-white px-4 md:px-6 max-w-5xl mx-auto flex flex-col items-center justify-center">
      <h2 class="text-accent-text font-heading font-bold text-3xl sm:text-4xl md:text-5xl tracking-widest uppercase mb-4 md:mb-6 drop-shadow-lg">
        MEGASHOP ARREDI
      </h2>
      <span class="block text-xs md:text-sm tracking-[0.2em] md:tracking-[0.3em] text-white/80 uppercase mb-4 md:mb-6 font-bold drop-shadow-md">
        {t('hero.badge')}
      </span>
      <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-bold mb-6 md:mb-8 font-heading drop-shadow-2xl leading-tight text-white tracking-tight">
        {t('hero.title')}
      </h1>
      <p class="text-base sm:text-lg md:text-xl lg:text-2xl font-light mb-8 md:mb-12 max-w-3xl mx-auto drop-shadow-lg text-white/95 leading-relaxed">
        {t('hero.subtitle')}
      </p>
      <a href="#collezioni" class="inline-flex items-center gap-3 bg-accent text-black px-8 md:px-10 py-4 md:py-5 uppercase tracking-widest text-xs md:text-sm font-bold hover:bg-white hover:text-text transition-all duration-500 shadow-2xl">
        {t('hero.cta')}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Categories Section -->
  <section id="collezioni" class="py-16 md:py-32 px-4 md:px-6 max-w-7xl mx-auto border-b border-border/50">
    <div class="text-center mb-12 md:mb-20">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading mb-4 md:mb-6 text-text">{t('collections.title')}</h2>
      <div class="w-16 md:w-20 h-1 bg-accent mx-auto"></div>
      <p class="mt-6 md:mt-8 text-text/70 max-w-2xl mx-auto font-light leading-relaxed text-base md:text-lg">
        {t('collections.subtitle')}
      </p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {categories.map(cat => (
        <CategoryCard 
          title={cat.title} 
          slug={cat.slug} 
          imagePath={getCoverForCategory(cat.slug)} 
        />
      ))}
    </div>
  </section>

  <!-- Brands Section (Elegant 3 Brands con 3 foto ciascuno) -->
  <section class="py-16 md:py-32 bg-primary border-b border-border/50">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="text-center mb-12 md:mb-20">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading mb-4 md:mb-6 text-text tracking-tight">{t('brands.title')}</h2>
        <div class="w-16 md:w-20 h-1 bg-accent mx-auto"></div>
        <p class="mt-6 md:mt-8 text-text/70 font-light max-w-xl mx-auto leading-relaxed text-base md:text-lg">
          {t('brands.subtitle')}
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12 w-full">
        {brandsWithImages.map(brand => (
           <a href={translatePath(`/brand/${brand.slug}`)} class="group block relative bg-white border border-border/60 hover:border-accent/40 shadow-[0_4px_20px_-10px_rgba(0,0,0,0.05)] hover:shadow-2xl transition-all duration-700 p-4 md:p-6 text-center overflow-hidden flex flex-col items-center w-full max-w-full">
            
            <!-- Images Collage -->
            <div class="w-full grid grid-cols-2 gap-2 md:gap-3 mb-6 md:mb-8 relative">
              {brand.images.length >= 1 ? (
                <div class="col-span-2 aspect-[16/9] overflow-hidden rounded-sm bg-border/20">
                   <Image src={brand.images[0]} alt={`${brand.name} main`} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-[2s]" width={600} height={337} />
                </div>
              ) : null}
              {brand.images.slice(1, 3).map(img => (
                <div class="aspect-[4/3] overflow-hidden rounded-sm bg-border/20">
                   <Image src={img} alt={`${brand.name} preview`} class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-[2s] delay-75" width={300} height={225} />
                </div>
              ))}
            </div>

            <!-- Text Box -->
            <div class="relative z-10 flex flex-col items-center justify-center pt-4 w-full border-t border-border/40 mt-auto">
              <h3 class="text-2xl font-heading font-bold text-text mb-4 tracking-wide group-hover:text-accent transition-colors duration-300">
                {brand.name}
              </h3>
              
              <span class="inline-flex items-center justify-center gap-2 text-xs font-bold tracking-widest uppercase text-text/75 group-hover:text-accent-text transition-colors duration-300">
                {t('nav.scopri')}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About Preview Section -->
  <section class="py-16 md:py-32 px-4 md:px-6 max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
    <div class="w-full lg:w-1/2 aspect-square md:aspect-[4/3] bg-border relative overflow-hidden h-[350px] sm:h-[500px] lg:h-auto shadow-2xl group">
      {getCoverForCategory('cucine') ? (
        <Image src={getCoverForCategory('cucine')} class="w-full h-full object-cover transform scale-100 group-hover:scale-110 transition-transform duration-[2s] ease-out" alt="Chi Siamo" loading="lazy" width={800} height={600} />
      ) : null}
      <div class="absolute inset-0 bg-black/10"></div>
    </div>
    <div class="w-full lg:w-1/2">
      <span class="block text-xs md:text-sm tracking-[0.2em] md:tracking-[0.3em] text-accent-text uppercase mb-3 md:mb-4 font-bold">{t('nav.chisiamo')}</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold font-heading mb-6 md:mb-8 text-text leading-tight">{t('home.about.title')}</h2>
      <p class="text-text/70 font-light leading-relaxed mb-4 md:mb-6 text-base md:text-lg">
        {t('home.about.p1')}
      </p>
      <p class="text-text/70 font-light leading-relaxed mb-8 md:mb-10 text-base md:text-lg">
        {t('home.about.p2')}
      </p>
      <a href={translatePath('/chi-siamo')} class="inline-flex items-center gap-2 md:gap-3 text-white bg-text px-6 md:px-8 py-3 md:py-4 tracking-widest hover:bg-accent transition-all uppercase text-xs md:text-sm font-bold shadow-lg">
        {t('home.about.cta')}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Dove Siamo Section -->
  <section class="py-16 md:py-24 px-4 md:px-6 max-w-7xl mx-auto border-t border-border/50">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
      
      <!-- Text Column -->
      <div class="w-full lg:w-1/2 flex flex-col justify-center">
        <span class="block text-xs md:text-sm tracking-[0.2em] md:tracking-[0.3em] text-accent-text uppercase mb-3 font-bold">{t('home.visit')}</span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold font-heading mb-8 text-text leading-tight">{t('home.visit.subtitle')}</h2>
        
        <div class="space-y-6 text-text/80 font-light text-base md:text-lg">
          <!-- Indirizzo -->
          <div class="flex items-start gap-4 pr-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent-text shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <p class="font-medium text-text mb-1">{t('home.address')}</p>
              <a href="https://maps.app.goo.gl/uYutyV15jDfAmnhV6" target="_blank" rel="noopener noreferrer" class="transition-colors duration-300 hover:text-accent-text hover:underline block">
                <p>Via Nazionale, 4</p>
                <p>92010 Alessandria della Rocca (AG)</p>
              </a>
            </div>
          </div>
          
          <!-- Contatti -->
          <div class="flex items-start gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent-text shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div>
              <p class="font-medium text-text mb-1">{t('home.phone')}</p>
              <p><a href="tel:3312527613" class="hover:text-accent-text transition-colors border-b border-transparent hover:border-accent">331 252 7613</a> (Domenico)</p>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent-text shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <div>
              <p class="font-medium text-text mb-1">{t('home.email')}</p>
              <p><a href="mailto:info@megashoparredi.it" class="hover:text-accent-text transition-colors border-b border-transparent hover:border-accent">info@megashoparredi.it</a></p>
            </div>
          </div>
          
          <!-- Orari -->
          <div class="flex items-start gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent-text shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <p class="font-medium text-text mb-1">{t('home.hours.title')}</p>
              <p>{t('footer.hours.val1')}: {t('footer.hours.val2')} / {t('footer.hours.val3')}</p>
              <p>{t('footer.hours.val4')}</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Map Column -->
      <div class="w-full lg:w-1/2 h-[400px] md:h-[500px] rounded-2xl overflow-hidden shadow-xl border border-border/30 group relative ring-1 ring-border/20 ring-offset-2">
        <div class="absolute inset-0 bg-accent/10 pointer-events-none mix-blend-multiply z-10 opacity-100 group-hover:opacity-0 transition-opacity duration-1000"></div>
        <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1575.6791986423456!2d13.4471032!3d37.5615797!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x131a1532f1ea38d5%3A0xc3af87265a7f2dc1!2sVia%20Nazionale%2C%204%2C%2092010%20Alessandria%20della%20Rocca%20AG!5e0!3m2!1sit!2sit!4v1703164996457!5m2!1sit!2sit" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="absolute inset-0 transition-transform duration-[2s] ease-out group-hover:scale-[1.02]"
            title={t('home.map.title')}
        ></iframe>
      </div>
      
    </div>
  </section>
</Layout>

<style>
  @keyframes subtleZoom {
    0% { transform: scale(1.02); }
    100% { transform: scale(1.10); }
  }
</style>
