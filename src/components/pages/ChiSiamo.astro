---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Image } from 'astro:assets';
import marco001 from '../../assets/images/foto-marco/marco001.jpg';
import marco002 from '../../assets/images/foto-marco/marco002.jpg';

const allImages = import.meta.glob('../../assets/images/immagini_tendaggi/*.{jpeg,jpg,png,webp}', { eager: true });
const imgList = Object.keys(allImages).sort().map(p => (allImages[p] as any).default);
const heroImg = imgList[5] ?? null;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<Layout
  title={t('nav.chisiamo')}
  description={t('about.meta.desc')}>

  <!-- Hero -->
  <section class="relative h-[60vh] min-h-[500px] w-full bg-black flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 w-full h-full opacity-55">
      {heroImg && <Image src={heroImg} alt={t('about.badge')} class="w-full h-full object-cover object-center scale-105" style="animation: subtleZoom 20s ease-in-out infinite alternate;" width={1920} height={800} loading="eager" />}
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20"></div>
    </div>
    <div class="relative z-10 text-center text-white px-6 max-w-4xl mx-auto mt-16">
      <span class="block text-sm tracking-[0.4em] text-white/60 font-bold uppercase mb-6">{t('about.badge')}</span>
      <h1 class="text-5xl md:text-7xl font-bold font-heading mb-6 text-white leading-tight tracking-tight">{t('about.title')}</h1>
      <p class="text-xl font-light text-white/85 leading-relaxed max-w-2xl mx-auto">{t('about.subtitle')}</p>
    </div>
  </section>

  <!-- Contenuto -->
  <section class="py-24 md:py-32 px-4 md:px-6 max-w-7xl mx-auto overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="space-y-7 text-text/75 font-light leading-relaxed text-lg">
        <h2 class="text-4xl md:text-5xl font-heading font-bold text-text mb-10 tracking-tight">
          {t('about.who')} <span class="text-accent-text">Marco Tendaggi</span>
        </h2>
        <p class="border-l-4 border-accent pl-6 italic text-text/85 text-xl font-heading">{t('about.quote')}</p>
        <p>{t('about.p1')}</p>
        <p>{t('about.p2')}</p>
        <p>{t('about.p3')}</p>
        <div class="mt-10 p-6 bg-surface border border-border/50 grid grid-cols-1 sm:grid-cols-2 gap-5 text-sm">
          <div>
            <p class="font-semibold text-text text-xs tracking-widest uppercase mb-1 text-accent-text">Showroom</p>
            <p>Via Canova 15 (il cangurotto)<br/>92016 Ribera (AG)</p>
          </div>
          <div>
            <p class="font-semibold text-text text-xs tracking-widest uppercase mb-1 text-accent-text">{t('about.markets.label')}</p>
            <p>✔ {t('home.markets.pe')}</p>
            <p>✔ {t('home.markets.fav')}</p>
          </div>
          <div>
            <p class="font-semibold text-text text-xs tracking-widest uppercase mb-1 text-accent-text">{t('home.phone')}</p>
            <a href="tel:3287323742" class="hover:text-accent-text transition-colors">328 732 3742</a>
          </div>
          <div>
            <p class="font-semibold text-text text-xs tracking-widest uppercase mb-1 text-accent-text">{t('about.coverage.label')}</p>
            <p>{t('about.coverage.val')}</p>
          </div>
        </div>
      </div>

      <!-- Foto Marco (proprietario) -->
      <div class="grid grid-cols-2 gap-4 relative">
        <div class="absolute -inset-4 bg-accent/5 -z-10 transform rotate-2"></div>
        <div class="aspect-[4/5] overflow-hidden shadow-2xl group col-span-1 rounded-xl">
          <Image src={marco001} alt="Marco Pellegrino — Marco Tendaggi" class="w-full h-full object-cover group-hover:scale-105 transition-all duration-[1.5s] ease-out" width={600} height={800} />
        </div>
        <div class="aspect-[4/5] overflow-hidden shadow-2xl mt-14 group col-span-1 rounded-xl">
          <Image src={marco002} alt="Marco Pellegrino nel suo showroom" class="w-full h-full object-cover group-hover:scale-105 transition-all duration-[1.5s] ease-out" width={600} height={800} />
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes subtleZoom {
    0% { transform: scale(1.02); }
    100% { transform: scale(1.10); }
  }
</style>
