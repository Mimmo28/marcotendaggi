---
// Cookie banner GDPR Component per Marco Tendaggi
---
<div id="cookie-banner" class="fixed bottom-0 left-0 w-full bg-primary/95 backdrop-blur-md border-t border-border z-[150] translate-y-full transition-transform duration-500 shadow-[0_-10px_40px_rgba(0,0,0,0.1)]">
  <div class="max-w-7xl mx-auto px-4 py-4 md:py-6 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="text-sm text-text/80 leading-relaxed max-w-4xl">
      Questo sito o gli strumenti terzi da questo utilizzati si avvalgono di cookie necessari al funzionamento ed utili alle finalità illustrate nella cookie policy. Se vuoi saperne di più o negare il consenso a tutti o ad alcuni cookie, consulta la nostra <a href="/privacy" class="text-accent font-medium hover:underline">Privacy & Cookie Policy</a>. Cliccando su "Accetta Tutti", acconsenti all'uso dei cookie.
    </div>
    <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto shrink-0 mt-2 md:mt-0">
      <button id="reject-cookies" class="w-full sm:w-auto bg-transparent border border-border text-text px-6 py-2.5 rounded-none font-medium text-sm hover:bg-border/50 hover:text-accent transition-colors whitespace-nowrap">
        Solo Essenziali
      </button>
      <button id="accept-cookies" class="w-full sm:w-auto bg-accent text-black px-6 py-2.5 rounded-none font-medium text-sm hover:bg-[#c98e18] shadow-lg shadow-accent/20 transition-all whitespace-nowrap">
        Accetta Tutti
      </button>
    </div>
  </div>
</div>

<script>
  function initCookieBanner() {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('accept-cookies');
    const rejectBtn = document.getElementById('reject-cookies');
    
    if (!banner || !acceptBtn || !rejectBtn) return;
    
    // Controlla il localStorage per vedere se c'è un consenso pregresso
    const cookieConsent = localStorage.getItem('marcotendaggi-cookie-consent');
    
    if (!cookieConsent) {
      // Rimuoviamo la dilazione temporale per garantire la visibilità immediata anche prima dello scroll
      banner.classList.remove('translate-y-full');
    }
    
    function hideBanner(choice: string) {
      localStorage.setItem('marcotendaggi-cookie-consent', choice);
      banner?.classList.add('translate-y-full');
    }
    
    acceptBtn.addEventListener('click', () => hideBanner('accepted'));
    rejectBtn.addEventListener('click', () => hideBanner('essential-only'));
  }
  
  // Binding per caricamento classico e View Transitions di Astro
  document.addEventListener('DOMContentLoaded', initCookieBanner);
  document.addEventListener('astro:page-load', initCookieBanner);
</script>
