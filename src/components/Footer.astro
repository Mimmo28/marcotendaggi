---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { Image } from "astro:assets";
import logoSito from "../assets/logo/logo-marco-tendaggi.png";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-surface border-t border-border pt-16 md:pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-6 sm:px-10">
    <!-- Top: brand + nav -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16 pb-16 border-b border-border">
      <!-- Brand -->
      <div class="md:col-span-4">
        <Image src={logoSito} alt="Marco Tendaggi" class="h-12 w-auto object-contain mb-5" loading="lazy" />
        <p class="text-text-muted font-light leading-relaxed text-sm max-w-xs mb-8">
          {t("footer.desc")}
        </p>
        <div class="flex gap-4">
          <a href={t('social.facebook')} target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-full border border-border flex items-center justify-center text-text/40 hover:text-accent-text hover:border-accent-text transition-all duration-300" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href={t('social.instagram')} target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-full border border-border flex items-center justify-center text-text/40 hover:text-accent-text hover:border-accent-text transition-all duration-300" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="md:col-span-2 md:col-start-6">
        <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-text mb-5">{t('footer.products')}</h3>
        <ul class="space-y-3 text-sm text-text-muted font-light">
          <li><a href="/collezioni/tende-interno" class="hover:text-accent-text transition-colors">{t('cat.tende-interno')}</a></li>
          <li><a href="/collezioni/tende-misura" class="hover:text-accent-text transition-colors">{t('cat.tende-misura')}</a></li>
          <li><a href="/collezioni/tessuti" class="hover:text-accent-text transition-colors">{t('cat.tessuti')}</a></li>
          <li><a href="/collezioni/binari" class="hover:text-accent-text transition-colors">{t('cat.binari')}</a></li>
          <li><a href="/collezioni/tende-rullo" class="hover:text-accent-text transition-colors">{t('cat.tende-rullo')}</a></li>
          <li><a href="/collezioni/veneziane" class="hover:text-accent-text transition-colors">{t('cat.veneziane')}</a></li>
        </ul>
      </div>

      <!-- Contatti -->
      <div class="md:col-span-3">
        <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-text mb-5">{t("footer.contacts")}</h3>
        <ul class="space-y-3 text-sm text-text-muted font-light">
          <li>
            <a href="https://maps.app.goo.gl/Gpne85oJ72oiizYH6" target="_blank" rel="noopener noreferrer" class="hover:text-accent-text transition-colors leading-relaxed block">
              Via Canova 15 (il cangurotto)<br/>92016 Ribera (AG)
            </a>
          </li>
          <li>
            <a href="tel:3287323742" class="hover:text-accent-text transition-colors">328 732 3742</a>
          </li>
          <li>
            <a href="mailto:info@marcotendaggi.it" class="hover:text-accent-text transition-colors">info@marcotendaggi.it</a>
          </li>
        </ul>
      </div>

      <!-- Mercati + Orari -->
      <div class="md:col-span-2">
        <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-text mb-5">{t("footer.markets")}</h3>
        <ul class="space-y-2 text-sm text-text-muted font-light mb-8">
          <li>✔ Porto Empedocle<br/><span class="text-xs text-text/40 ml-4">{t('footer.day.thu')}</span></li>
          <li>✔ Favara<br/><span class="text-xs text-text/40 ml-4">{t('footer.day.fri')}</span></li>
        </ul>
        <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-text mb-3">{t("footer.hours")}</h3>
        <p class="text-sm text-text-muted font-light leading-relaxed">
          {t('footer.hours.weekday')}<br/>09:00–13:00 / 16:00–20:00<br/>
          <span class="text-xs text-text/40">{t('footer.hours.weekend')}</span>
        </p>
      </div>
    </div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-text/40">
      <div class="flex flex-col gap-1 text-center md:text-left">
        <p>&copy; {year} Marco Tendaggi. {t("footer.rights")}</p>
        <p>P.IVA: 02819550845 &nbsp;|&nbsp; C.F.: PGLMRC95T27I356Z</p>
      </div>
      <div class="flex gap-5">
        <a href="/privacy" class="hover:text-accent-text transition-colors">Privacy & Cookie Policy</a>
      </div>
      <p>Engineered by <a href="https://www.instagram.com/domenico.innamorato" target="_blank" rel="noopener noreferrer" class="hover:text-accent-text transition-colors font-medium">The Dev Heart</a></p>
    </div>
  </div>
</footer>
