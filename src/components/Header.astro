---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
import type { ui } from '../i18n/ui';
import { Image } from 'astro:assets';
import logoSito from '../assets/logo/logo-marco-tendaggi.png';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', labelKey: 'nav.home' as keyof typeof ui['it'] },
  { href: '/#collezioni', labelKey: 'nav.collezioni' as keyof typeof ui['it'] },
  { href: '/chi-siamo', labelKey: 'nav.chisiamo' as keyof typeof ui['it'] },
  { href: '/contatti', labelKey: 'nav.contatti' as keyof typeof ui['it'] },
];

const subMenuLinks = [
  { href: '/collezioni/tende-interno',   labelKey: 'nav.sub.tende-interno'    },
  { href: '/collezioni/tende-misura',    labelKey: 'nav.sub.tende-misura'     },
  { href: '/collezioni/tessuti',         labelKey: 'nav.sub.tessuti'          },
  { href: '/collezioni/binari',          labelKey: 'nav.sub.binari'           },
  { href: '/collezioni/tende-rullo',     labelKey: 'nav.sub.tende-rullo'      },
  { href: '/collezioni/veneziane',       labelKey: 'nav.sub.veneziane'        },
  { href: '/collezioni/devore',          labelKey: 'nav.sub.devore'           },
  { href: '/collezioni/jeorgette-seta',  labelKey: 'nav.sub.jeorgette-seta'   },
  { href: '/collezioni/jeorgette-calata',labelKey: 'nav.sub.jeorgette-calata' },
  { href: '/collezioni/misto-lino',      labelKey: 'nav.sub.misto-lino'       },
  { href: '/collezioni/oceania',         labelKey: 'nav.sub.oceania'          },
];
---

<!-- Header stile Colombo: sfondo sabbia, logo sinistra, nav centro, pill CTA destra -->
<header id="site-header" class="sticky top-0 z-50 bg-primary/90 backdrop-blur-md border-b border-border/60 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 h-18 md:h-20 flex items-center justify-between gap-6">
    
    <!-- Logo -->
    <a href={translatePath('/')} class="shrink-0 group">
      <Image 
        src={logoSito} 
        alt="Marco Tendaggi" 
        class="h-12 md:h-14 w-auto object-contain group-hover:opacity-80 transition-opacity duration-300" 
        loading="eager" 
        fetchpriority="high" 
      />
    </a>

    <!-- Desktop Nav (centro) -->
    <nav class="hidden lg:flex items-center gap-7 flex-1 justify-center">
      {links.map((link) => {
        const translatedHref = translatePath(link.href);
        const isCollections = link.labelKey === 'nav.collezioni';
        const isActive = !isCollections && (currentPath === translatedHref || (link.href !== '/' && currentPath.startsWith(translatedHref)));
        
        return isCollections ? (
          <div class="relative group flex items-center h-20">
            <a 
              href={translatePath('/#collezioni')} 
              class={`text-sm font-medium transition-colors hover:text-accent-text flex items-center gap-1 ${isActive ? 'text-accent-text' : 'text-text/75'}`}
            >
              {t(link.labelKey)}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transform group-hover:-rotate-180 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <!-- Dropdown -->
            <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[440px] bg-surface border border-border shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 origin-top p-6 grid grid-cols-2 gap-3 rounded-xl">
              {subMenuLinks.map(sub => (
                <a href={translatePath(sub.href)} class="text-sm text-text/65 hover:text-accent-text transition-colors py-2 px-3 rounded-lg hover:bg-primary/50">
                  {t(sub.labelKey as any)}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a 
            href={translatedHref} 
            class={`text-sm font-medium transition-colors hover:text-accent-text ${isActive ? 'text-accent-text' : 'text-text/75'}`}
          >
            {t(link.labelKey)}
          </a>
        );
      })}

      <!-- Lang -->
      <div class="flex items-center gap-1.5 text-xs font-semibold text-text/50">
        <a href="/" class={`hover:text-accent-text transition-colors ${lang === 'it' ? 'text-accent-text' : ''}`}>IT</a>
        <span>/</span>
        <a href="/en" class={`hover:text-accent-text transition-colors ${lang === 'en' ? 'text-accent-text' : ''}`}>EN</a>
      </div>
    </nav>

    <!-- CTA pill (destra) -->
    <div class="hidden lg:flex items-center shrink-0">
      <a href="/contatti" class="btn-pill text-sm whitespace-nowrap">
        {t('nav.chiamaci')}
      </a>
    </div>

    <!-- Mobile: hamburger -->
    <button class="lg:hidden p-2 text-text hover:text-accent-text transition-colors" aria-label="Menu" id="mobile-menu-btn">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu-overlay" class="fixed inset-0 bg-black/50 z-[60] opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>
<div id="mobile-menu" class="fixed inset-y-0 left-0 w-[85%] max-w-sm bg-surface z-[70] transform -translate-x-full invisible transition-all duration-400 ease-in-out flex flex-col pt-6 px-6 lg:hidden overflow-y-auto shadow-2xl">
  <div class="flex items-center justify-between mb-10">
    <Image src={logoSito} alt="Marco Tendaggi" class="h-10 w-auto object-contain" loading="eager" />
    <button id="close-menu-btn" aria-label={t('header.aria.close')} class="p-2 text-text hover:text-accent-text transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  
  <nav class="flex flex-col gap-1 flex-1">
    {links.map((link) => {
      const isCollections = link.labelKey === 'nav.collezioni';
      const translatedHref = isCollections ? '/#collezioni' : translatePath(link.href);
      
      return isCollections ? (
        <div class="flex flex-col">
          <div class="flex items-center justify-between" id="mobile-collections-toggle">
            <a href={translatedHref} class="text-lg font-medium text-text py-3 hover:text-accent-text transition-colors">
              {t(link.labelKey)}
            </a>
            <button id="mobile-collections-icon" class="p-2" aria-label={t('header.aria.expand')}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-text/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>
          <div id="mobile-collections-menu" class="overflow-hidden max-h-0 opacity-0 transition-all duration-300 pl-4">
            {subMenuLinks.map(sub => (
              <a href={translatePath(sub.href)} class="block text-sm text-text/60 py-2 hover:text-accent-text transition-colors border-l border-border/50 pl-4">
                {t(sub.labelKey as any)}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a href={translatedHref} class="text-lg font-medium text-text py-3 border-b border-border/30 hover:text-accent-text transition-colors">
          {t(link.labelKey)}
        </a>
      );
    })}
  </nav>

  <div class="py-8 flex flex-col gap-4">
    <a href="/contatti" class="btn-pill text-center">
      {t('nav.chiamaci')}
    </a>
    <div class="flex items-center justify-center gap-3 text-sm text-text/50">
      <a href="/" class={lang === 'it' ? 'text-accent-text font-semibold' : ''}>IT</a>
      <span>/</span>
      <a href="/en" class={lang === 'en' ? 'text-accent-text font-semibold' : ''}>EN</a>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');

  if (btn && menu && closeBtn && overlay) {
    const openMenu = () => {
      menu.classList.remove('invisible');
      requestAnimationFrame(() => {
        menu.classList.remove('-translate-x-full');
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        document.body.style.overflow = 'hidden';
      });
    };
    const closeMenu = () => {
      menu.classList.add('-translate-x-full');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
      setTimeout(() => menu.classList.add('invisible'), 400);
    };
    btn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    overlay.addEventListener('click', closeMenu);
  }

  const colToggle = document.getElementById('mobile-collections-toggle');
  const colIcon = document.getElementById('mobile-collections-icon');
  const colMenu = document.getElementById('mobile-collections-menu');

  if (colToggle && colIcon && colMenu) {
    colToggle.addEventListener('click', (e) => {
      if ((e.target as Element).closest('button')) e.preventDefault();
      const isOpen = !colMenu.classList.contains('max-h-0');
      if (!isOpen) {
        colMenu.classList.remove('max-h-0', 'opacity-0');
        colMenu.classList.add('max-h-[400px]', 'opacity-100', 'mt-1', 'mb-3');
        colIcon.classList.add('rotate-180');
      } else {
        colMenu.classList.add('max-h-0', 'opacity-0');
        colMenu.classList.remove('max-h-[400px]', 'opacity-100', 'mt-1', 'mb-3');
        colIcon.classList.remove('rotate-180');
      }
    });
  }
</script>
