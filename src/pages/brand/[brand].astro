---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

export function getStaticPaths() {
  const brands = [
    { name: "Tendaggi Classici", slug: "catilan_soggiorni", description: "Tende classiche e drappeggi eleganti per ambienti raffinati. Tessuti pregiati e confezione artigianale su misura da Marco Tendaggi a Ribera (AG)." },
    { name: "Tende Moderne", slug: "divancasa", description: "Linee pulite e tessuti contemporanei per tende da interno di design. Soluzioni moderne con posa professionale in tutta la provincia di Agrigento." },
    { name: "Esterno e Giardino", slug: "proxima_mobili", description: "Tende da sole, pergole e protezioni per esterni. Materiali resistenti alle intemperie e soluzioni estetiche per terrazze e giardini a Ribera." }
  ];

  return brands.map(brand => ({
    params: { brand: brand.slug },
    props: { brandData: brand },
  }));
}

const { brand } = Astro.params;
const { brandData } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const allBrandsGlob = import.meta.glob('/public/images/brand/**/*.{jpeg,jpg,png,webp}', { eager: true });
const brandImages = Object.keys(allBrandsGlob)
  .filter(path => path.includes(`/public/images/brand/${brand}/`))
  .map(path => path.replace('/public', ''));
---

<Layout title={`${brandData.name} | Brand`} description={brandData.description}>
  <section class="pt-32 pb-24 px-6 max-w-7xl mx-auto text-center border-b border-border/50">
    <a href={translatePath('/')} class="inline-flex items-center gap-2 text-text/50 hover:text-accent-text transition-colors text-sm uppercase tracking-widest mb-10 font-bold">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      {t('nav.back.home')}
    </a>
    
    <h1 class="text-5xl md:text-7xl font-bold font-heading mb-8 text-text tracking-tight uppercase">{brandData.name}</h1>
    <div class="w-16 h-1 bg-accent mx-auto mb-8"></div>
    <p class="text-xl font-light text-text/70 max-w-3xl mx-auto leading-relaxed">
      {brandData.description}
    </p>
  </section>

  <section class="py-24 px-6 max-w-7xl mx-auto min-h-[50vh]">
    {brandImages.length > 0 ? (
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-8 space-y-8">
        {brandImages.map((img, index) => (
          <div class="break-inside-avoid relative group overflow-hidden bg-white shadow-lg shadow-black/5 hover:shadow-2xl transition-shadow duration-500 rounded-sm">
            <img 
              src={img} 
              alt={`${brandData.name} - Immagine ${index + 1}`} 
              class="w-full h-auto object-cover transform group-hover:scale-[1.05] transition-transform duration-[1.5s] ease-out"
              loading="lazy"
              data-lightbox="true"
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="w-full flex flex-col items-center justify-center py-32 text-center bg-primary border border-border/50">
        <h3 class="text-3xl font-heading font-bold text-text mb-4 tracking-tight">{t('category.gallery_updating')}</h3>
        <p class="text-text/60 font-light text-lg">{t('category.gallery_desc')}</p>
      </div>
    )}
  </section>
</Layout>
