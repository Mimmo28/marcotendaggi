---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../../i18n/utils';
import { Image } from 'astro:assets';

export function getStaticPaths() {
  const categories = [
    { title: "Interior Curtains",              slug: "tende-interno",     description: "Discover our custom interior curtains. Precious fabrics, elegant design and professional installation to transform every room of your home." },
    { title: "Custom Curtains",               slug: "tende-misura",      description: "Bespoke curtains crafted with premium fabrics and artisan techniques. Tailored solutions for every space, from consultation to installation." },
    { title: "Precious Fabrics",               slug: "tessuti",           description: "An exclusive selection of precious fabrics for curtains and drapes. High-quality materials for every style and environment." },
    { title: "Tracks & Accessories",           slug: "binari",            description: "High-quality curtain tracks, rods and accessories. Functional and aesthetic solutions for the perfect installation of your curtains." },
    { title: "Roller Blinds",                  slug: "tende-rullo",       description: "Modern and practical roller blinds for perfect light control. Available in numerous fabrics and colors to suit every decor." },
    { title: "Venetian Blinds & Panels",       slug: "veneziane",         description: "Venetian blinds and sliding panels as a modern and functional alternative to traditional curtains." },
    { title: "Devorè",                         slug: "devore",            description: "High-quality Devorè fabric: relief velvet that adds elegance and depth to your custom curtains." },
    { title: "Silk Georgette",                 slug: "jeorgette-seta",    description: "Pure silk georgette: lightness, sheen and impeccable drape for curtains of great refinement." },
    { title: "Georgette with Drop or Velvet",  slug: "jeorgette-calata",  description: "Georgette with drop or combined with velvet: a combination of soft textures for a unique tailored effect." },
    { title: "Linen Mix",                      slug: "misto-lino",        description: "Natural and breathable linen mix fabrics, ideal for a warm and welcoming atmosphere in any environment." },
    { title: "Oceania",                        slug: "oceania",           description: "The Oceania collection: technical and decorative fabrics for modern and bright spaces." },
  ];

  return categories.map(cat => ({
    params: { categoria: cat.slug },
    props: { category: cat },
  }));
}

const { categoria } = Astro.params;
const { category } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// General tendaggi images
const allImages    = import.meta.glob('../../../assets/images/immagini_tendaggi/*.{jpeg,jpg,png,webp}', { eager: true });
const allImgList   = Object.keys(allImages).sort().map(p => (allImages[p] as any).default);

// Dedicated folders
const gBinari      = import.meta.glob('../../../assets/images/binari/*.{jpeg,jpg,png,webp}', { eager: true });
const gDevore      = import.meta.glob('../../../assets/images/devorè/*.{jpeg,jpg,png,webp}', { eager: true });
const gJeorSeta    = import.meta.glob('../../../assets/images/jeorgette-in-seta/*.{jpeg,jpg,png,webp}', { eager: true });
const gJeorCal     = import.meta.glob('../../../assets/images/jeorgette-in-seta-con-calata-o-velluto/*.{jpeg,jpg,png,webp}', { eager: true });
const gMistoLino   = import.meta.glob('../../../assets/images/misto-lino/*.{jpeg,jpg,png,webp}', { eager: true });
const gOceania     = import.meta.glob('../../../assets/images/oceania/*.{jpeg,jpg,png,webp}', { eager: true });

const toList = (g: Record<string, any>) => Object.values(g).map((m: any) => m.default);

const dedicated: Record<string, any[]> = {
  'binari':           toList(gBinari),
  'devore':           toList(gDevore),
  'jeorgette-seta':   toList(gJeorSeta),
  'jeorgette-calata': toList(gJeorCal),
  'misto-lino':       toList(gMistoLino),
  'oceania':          toList(gOceania),
};

const ranges: Record<string, [number, number]> = {
  'tende-interno': [0,   20],
  'tende-misura': [20,  40],
  'tessuti':       [40,  60],
  'tende-rullo':   [60,  80],
  'veneziane':     [80, 100],
};

const categoryImages: any[] = dedicated[categoria]
  ? dedicated[categoria]
  : allImgList.slice(...(ranges[categoria] ?? [0, 20]));

const heroImage = categoryImages[0] ?? null;
---
<Layout title={`${category.title} | Marco Tendaggi`} description={category.description}>
  <!-- Hero -->
  <section class="relative h-[45vh] min-h-[360px] md:min-h-[420px] w-full bg-black flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 w-full h-full opacity-55">
      {heroImage && <Image src={heroImage} alt={`${category.title} Hero`} class="w-full h-full object-cover object-center" loading="eager" width={1920} height={420} />}
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/20"></div>
    </div>
    <div class="relative z-10 text-center text-white px-6 w-full max-w-4xl mx-auto mt-12 pb-4">
      <a href={translatePath('/#collezioni')} class="inline-flex items-center justify-center gap-2 text-white/70 hover:text-white transition-colors text-xs uppercase tracking-widest mb-6 font-bold">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        {t('category.back')}
      </a>
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold font-heading mb-5 text-white drop-shadow-2xl tracking-tight">{category.title}</h1>
      <div class="w-14 h-px bg-white/50 mx-auto mb-5"></div>
      <p class="text-base sm:text-lg font-light text-white/85 max-w-2xl mx-auto leading-relaxed">{category.description}</p>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-20 md:py-28 px-4 md:px-6 max-w-7xl mx-auto min-h-[50vh]">
    {categoryImages.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {categoryImages.map((img, index) => (
          <div class="relative group overflow-hidden bg-surface shadow-md hover:shadow-2xl transition-shadow duration-500">
            <div class="aspect-[4/3] overflow-hidden">
              <Image
                src={img}
                alt={`${category.title} - ${index + 1}`}
                class="w-full h-full object-cover transform group-hover:scale-[1.05] transition-transform duration-[1.5s] ease-out"
                loading="lazy"
                width={800}
                height={600}
              />
            </div>
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-500 pointer-events-none flex items-center justify-center opacity-0 group-hover:opacity-100">
              <div class="w-14 h-14 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center border border-white/30 transform scale-50 group-hover:scale-100 transition-all duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="w-full flex flex-col items-center justify-center py-32 text-center border border-border/50">
        <h3 class="text-3xl font-heading font-bold text-text mb-3">{t('category.gallery_updating')}</h3>
        <p class="text-text/50 font-light text-lg">{t('category.gallery_desc')}</p>
      </div>
    )}
  </section>

  <!-- CTA -->
  <section class="py-14 px-4 border-t border-border/50 bg-surface">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-text/70 font-light text-lg mb-6">Interested in <strong class="text-text font-semibold">{category.title}</strong>? Request a free quote with no commitment.</p>
      <a href="/en/contatti" class="inline-flex items-center gap-3 bg-accent text-white px-10 py-4 uppercase tracking-widest text-sm font-bold hover:bg-text transition-all duration-300 shadow-lg">
        Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </section>
</Layout>
