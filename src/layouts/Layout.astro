---
import '../styles/global.css';
import '../styles/fonts.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactFAB from '../components/ContactFAB.astro';
import Lightbox from '../components/Lightbox.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { getLangFromUrl } from '../i18n/utils';
import { languages, defaultLang } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const { 
  title, 
  description = "Marco Tendaggi — Tendaggi, tessuti e binari pregiati su misura. Preventivi gratuiti in tutta Italia. Showroom a Ribera (AG), Via Canova 15.",
  noindex = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const getAlternateUrl = (l: string) => {
  const parts = Astro.url.pathname.split('/').filter(Boolean);
  if (Object.keys(languages).includes(parts[0])) parts.shift();
  const base = parts.join('/');
  const newPath = l === defaultLang ? `/${base}` : `/${l}/${base}`;
  return new URL(newPath.replace(/\/$/, '') || '/', Astro.site);
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo/icona_sito.png" />
    <title>{title} | Marco Tendaggi</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {Object.keys(languages).map((l) => (
      <link rel="alternate" hreflang={l} href={getAlternateUrl(l)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={getAlternateUrl(defaultLang)} />
    
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HomeAndConstructionBusiness",
        "name": "Marco Tendaggi",
        "description": "Tendaggi, tessuti pregiati e binari su misura. Preventivi gratuiti in tutta Italia.",
        "url": "https://www.marcotendaggi.it",
        "telephone": "+393287323742",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Via Canova 15",
          "addressLocality": "Ribera",
          "postalCode": "92016",
          "addressRegion": "AG",
          "addressCountry": "IT"
        }
      }
    </script>

    <!-- CSP: hardenata — font serviti localmente, no richieste a Google Fonts -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https:; frame-src 'self' https://www.google.com/maps/; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;" />
    
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Marco Tendaggi" />
    <meta property="og:title" content={title ? `${title} | Marco Tendaggi` : "Marco Tendaggi — Tendaggi e Tessuti Pregiati"} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={new URL('/images/logo_whatsapp.jpg', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ? `${title} | Marco Tendaggi` : "Marco Tendaggi"} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/images/logo_whatsapp.jpg', Astro.site)} />
    
    <!-- Font locali: Playfair Display + Inter (GDPR-compliant, zero richieste esterne) -->
    <link rel="preload" href="/fonts/inter-latin-regular.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/playfair-400-normal-latin.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    
    <style is:inline>
      .hero-slide { opacity: 0; }
      .hero-slide:first-child { opacity: 1; }
    </style>
  </head>
  <body class="antialiased min-h-screen flex flex-col bg-primary text-text selection:bg-accent selection:text-white w-full max-w-full overflow-x-clip">
    <Header />
    <main class="flex-grow overflow-x-clip">
      <slot />
    </main>
    <Footer />
    <ContactFAB />
    <Lightbox />
    <CookieBanner />
  </body>
</html>
